# ==== Backend SnapFiche — variables d'environnement (à configurer dans Render) ====

# Supabase (Project Settings -> API)
SUPABASE_URL=https://jljemjqlufbaqlpaziog.supabase.co
SUPABASE_SERVICE_ROLE=colle_ici_la_cle_service_role_SECRETE

# Connexion PostgreSQL directe (Supabase -> bouton "Connect" -> URI). Contient le mot de passe DB.
DATABASE_URL=postgresql://postgres.jljemjqlufbaqlpaziog:MOT_DE_PASSE@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Clé API kie.ai (la même que dans l'app de bureau)
KIE_API_KEY=colle_ici_ta_cle_kie

# Origine autorisée (le frontend). En prod : https://snapfiche.com
# En dev local, tu peux mettre http://localhost:5173 (ou *)
ALLOWED_ORIGIN=https://snapfiche.com

# Port (Render le fournit automatiquement ; en local 3000)
PORT=3000
